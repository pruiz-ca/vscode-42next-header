{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2022",
    "lib": ["ES2022"],
    "outDir": "out",
    "rootDir": ".",
    "types": ["node"],
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "exactOptionalPropertyTypes": true,
    "sourceMap": true,
    "removeComments": true
  },
  "exclude": [
    "node_modules",
    ".vscode-test",
    "src/test"
  ]
}
